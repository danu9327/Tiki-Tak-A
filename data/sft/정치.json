				}
			],
			"turn_id": "038757-3",
			"utterance_id": "038757.5"
		},
		{
			"speaker": "speakerB",
			"text": "진짜야? 몽골에도 한국 문화가 엄청난가 봐?",
			"new_word": "",
			"speech_act": "정보 요청",
			"slot": [
				{
					"key": "지역/장소/조직",
					"value": "한국; 몽골"
